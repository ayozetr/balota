# Node
node_modules/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
out/
build/
*.AppImage
*.deb
*.rpm

# Rust / Tauri
# Cargo.lock is committed on purpose: this crate builds a binary, so pinned
# dependency versions are what makes a build reproducible.
src-tauri/target/
src-tauri/gen/
src-tauri/binaries/
*.rs.bk

# Signing keys and secrets. The Tauri updater's private key must never end up
# in a commit — it is the one thing that cannot be rotated quietly, since every
# installed client trusts it.
*.key
*.pem
*.p12
*.pfx
*.jks
.env
.env.*
!.env.example

# Editors and OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.sw?
.claude/settings.local.json

# Local
*.local
*.log
.cache/
coverage/
src-tauri/binaries/
